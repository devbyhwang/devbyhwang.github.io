---
layout: layouts/base.njk
brand: devbyhwang
title: 홈
description: "Playground와 개발 기록을 모아둔 DevByHwang 홈."
---
{% set playgroundItems = [] %}
{% for project in studio.games %}
  {% if project.type == 'demo' %}
    {% set playgroundItems = (playgroundItems.push(project), playgroundItems) %}
  {% endif %}
{% endfor %}
{% set devPosts = collections.devPosts %}

<section class="page-hero">
  <h1>Playground</h1>
</section>

<section class="layout-two" id="latest">
  <div class="feed">
    {% if playgroundItems.length > 0 %}
    <div class="playground-section playground-section-home">
      <div class="playground-grid home-playground-grid">
        {% for item in playgroundItems %}
          {% set launch = item.links | first %}
          <article class="playground-card">
            {% if item.preview %}
            <div class="card-preview">
              <img src="{{ item.preview | url }}" alt="{{ item.title }} 프리뷰" loading="lazy" />
            </div>
            {% endif %}
            <div class="project-meta">
              {% if item.status %}<span class="badge">{{ item.status }}</span>{% endif %}
              {% if item.role %}<span class="pill">{{ item.role }}</span>{% endif %}
            </div>
            <h3>{{ item.title }}</h3>
            <p class="muted">{{ item.blurb }}</p>
            {% if launch %}
            <div class="inline-links">
              <a href="{{ launch.href | url }}">{{ launch.label }} →</a>
            </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    <div class="section-header">
      <h2>최신 글</h2>
    </div>
    {% set posts = devPosts %}
    {% set defaultCategory = "devlog" %}
    {% set limit = 8 %}
    {% set emptyMessage = "아직 글이 없습니다." %}
    {% set listClass = "post-list archive-list writing-feed-list" %}
    {% set itemClass = "writing-feed-item" %}
    {% set showExcerpt = true %}
    {% include "partials/writing-feed-cards.njk" %}

    {% include "ad-slot.njk" %}
  </div>

  <aside class="sidebar">
    <div class="sidebar-categories">
      <div class="sidebar-title">카테고리</div>
      <ul class="category-tree">
        <li>
          <a href="{{ '/devbyhwang/blog/' | url }}">전체글</a>
          <span class="count">({{ devPosts | length }})</span>
        </li>
        {% for cat in collections.devCategoryList %}
          <li class="sub">
            <a href="{{ ('/devbyhwang/categories/' + cat.key + '/') | url }}">{{ cat.name }}</a>
            <span class="count">({{ cat.count }})</span>
          </li>
        {% endfor %}
      </ul>
    </div>

    {% include "ad-slot.njk" %}
  </aside>
</section>
