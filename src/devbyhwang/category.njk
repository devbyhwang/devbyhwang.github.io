---
layout: layouts/base.njk
brand: devbyhwang
pagination:
  data: collections.devCategoryList
  size: 1
  alias: category
permalink: "/devbyhwang/categories/{{ category.key }}/"
eleventyComputed:
  title: "{{ category.name }}"
  description: "{{ category.name }} 카테고리 글 모음"
---
{% set categoryPosts = collections.devPosts | postsByCategory(category) %}
{% set gamesPlayground = [] %}
{% if category.key == 'games' %}
  {% for project in studio.games %}
    {% if project.type == 'demo' %}
      {% set gamesPlayground = (gamesPlayground.push(project), gamesPlayground) %}
    {% endif %}
  {% endfor %}
{% endif %}

<section class="page-hero">
  <h1>{{ category.name }}</h1>
</section>

<section class="layout-two archive">
  <div class="feed">
    {% set posts = categoryPosts %}
    {% set defaultCategory = "devlog" %}
    {% set emptyMessage = "아직 이 카테고리에 작성된 글이 없습니다." %}
    {% set listClass = "post-list archive-list writing-feed-list" %}
    {% set itemClass = "writing-feed-item" %}
    {% set showExcerpt = true %}
    {% include "partials/writing-feed-cards.njk" %}

    {% if gamesPlayground.length > 0 %}
    <section class="related-cards">
      <div class="section-header">
        <h2>Playground</h2>
      </div>
      <div class="playground-grid">
        {% for item in gamesPlayground %}
          {% set launch = item.links | first %}
          <article class="playground-card">
            {% if item.preview %}
            <div class="card-preview">
              <img src="{{ item.preview | url }}" alt="{{ item.title }} 프리뷰" loading="lazy" />
            </div>
            {% endif %}
            <div class="project-meta">
              {% if item.status %}<span class="badge">{{ item.status }}</span>{% endif %}
              {% if item.role %}<span class="pill">{{ item.role }}</span>{% endif %}
            </div>
            <h3>{{ item.title }}</h3>
            <p class="muted">{{ item.blurb }}</p>
            {% if launch %}
            <div class="inline-links">
              <a href="{{ launch.href | url }}">{{ launch.label }} →</a>
            </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </section>
    {% endif %}
  </div>
  <aside class="sidebar">
    <div class="sidebar-categories">
      <div class="sidebar-title">카테고리</div>
      <ul class="category-tree">
        {% for cat in collections.devCategoryList %}
          <li{% if cat.key == category.key %} class="active"{% endif %}>
            <a href="{{ ('/devbyhwang/categories/' + cat.key + '/') | url }}">{{ cat.name }}</a>
            <span class="count">({{ cat.count }})</span>
          </li>
        {% endfor %}
      </ul>
    </div>
  </aside>
</section>
