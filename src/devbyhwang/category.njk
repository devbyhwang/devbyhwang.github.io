---
layout: layouts/base.njk
brand: devbyhwang
pagination:
  data: collections.devCategoryList
  size: 1
  alias: category
permalink: "/devbyhwang/categories/{{ category.key }}/"
eleventyComputed:
  title: "{{ category.name }}"
  description: "{{ category.name }} 카테고리 글 모음"
---
{% set categoryPosts = collections.devPosts | postsByCategory(category) %}

<section class="page-hero">
  <h1>{{ category.name }}</h1>
</section>

<section class="layout-two archive">
  <div class="feed">
    {% set posts = categoryPosts %}
    {% set defaultCategory = "devlog" %}
    {% set emptyMessage = "아직 이 카테고리에 작성된 글이 없습니다." %}
    {% set listClass = "post-list archive-list writing-feed-list" %}
    {% set itemClass = "writing-feed-item" %}
    {% set showExcerpt = true %}
    {% include "partials/writing-feed-cards.njk" %}
  </div>
  <aside class="sidebar">
    <div class="sidebar-categories">
      <div class="sidebar-title">카테고리</div>
      <ul class="category-tree">
        {% for cat in collections.devCategoryList %}
          <li{% if cat.key == category.key %} class="active"{% endif %}>
            <a href="{{ ('/devbyhwang/categories/' + cat.key + '/') | url }}">{{ cat.name }}</a>
            <span class="count">({{ cat.count }})</span>
          </li>
        {% endfor %}
      </ul>
    </div>
  </aside>
</section>
