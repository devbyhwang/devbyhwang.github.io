{% if brand and brands[brand] %}
  {% set activeBrand = brands[brand] %}
{% else %}
  {% set activeBrand = null %}
{% endif %}
{% if activeBrand %}
  {% set themeClass = activeBrand.themeClass %}
{% else %}
  {% set themeClass = 'theme-hub' %}
{% endif %}
{% set devNewest = collections.devPosts | first %}
{% set dodoesNewest = collections.dodoesWriting | first %}
{% if devNewest and dodoesNewest %}
  {% if devNewest.date > dodoesNewest.date %}
    {% set overallNewest = devNewest %}
  {% else %}
    {% set overallNewest = dodoesNewest %}
  {% endif %}
{% else %}
  {% set overallNewest = devNewest or dodoesNewest %}
{% endif %}
{% if brand == 'devbyhwang' %}
  {% set brandNewest = devNewest %}
{% elif brand == 'dodoes' %}
  {% set brandNewest = dodoesNewest %}
{% else %}
  {% set brandNewest = null %}
{% endif %}
<!doctype html>
<html lang="ko">
  <head>
    {% set siteName = activeBrand.displayName if activeBrand else site.title %}
    {% set pageTitle = title or '' %}
    {% set docTitle = '블로그' %}
    {% if pageTitle and siteName %}
      {% set docTitle = pageTitle + ' · ' + siteName %}
    {% elif pageTitle %}
      {% set docTitle = pageTitle %}
    {% elif siteName %}
      {% set docTitle = siteName %}
    {% endif %}
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' https://pagead2.googlesyndication.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://cdn.jsdelivr.net https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.counterapi.dev; frame-src https://googleads.g.doubleclick.net https://tpc.googlesyndication.com; object-src 'none'; base-uri 'self'; form-action 'self'"
    />
    <title>{{ docTitle }}</title>
    <meta name="description" content="{{ excerpt or description or (activeBrand and activeBrand.description) or site.description }}" />
    <link rel="canonical" href="{{ canonicalUrl or (site.url + (page.url | url)) }}" />
    <link rel="icon" type="image/png" sizes="32x32" href="{{ '/assets/icons/favicon-32x32.png' | url }}" />
    <link rel="icon" type="image/png" sizes="16x16" href="{{ '/assets/icons/favicon-16x16.png' | url }}" />
    <link rel="shortcut icon" href="{{ '/assets/icons/favicon.png' | url }}" />
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/icons/apple-touch-icon.png' | url }}" />
    <meta name="msapplication-TileImage" content="{{ '/assets/icons/android-chrome-192x192.png' | url }}" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css" rel="stylesheet" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,700&family=Noto+Serif+KR:wght@400;500;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="{{ '/styles/main.css' | url }}" />

    {% if activeBrand and activeBrand.features.ads and site.googleAds.enable and site.googleAds.client and env.isProd %}
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client={{ site.googleAds.client }}"
      crossorigin="anonymous"
    ></script>
    {% endif %}
  </head>
  <body class="{{ themeClass }}">
    {% if activeBrand %}
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <aside class="sidebar-drawer" id="sidebar-drawer">
      <button class="drawer-close" id="drawer-close" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <nav class="drawer-nav">
        {% for item in activeBrand.nav %}
        <a href="{{ item.href | url }}">{{ item.label }}</a>
        {% endfor %}
      </nav>
    </aside>
    {% endif %}

    <header class="site-header{% if not activeBrand %} hub-header{% endif %}" id="site-header">
      <div class="header-inner">
        {% set brandTitleText = activeBrand.displayName if activeBrand else site.title %}
        {% set brandTaglineText = activeBrand.tagline if activeBrand else site.tagline %}
        <div class="brand{% if not brandTitleText and not brandTaglineText %} is-empty{% endif %}">
          <a class="brand-home" href="{{ (activeBrand and activeBrand.homeHref or '/') | url }}">
            {% if brandTitleText %}
            <div class="brand-title">{{ brandTitleText }}</div>
            {% endif %}
            {% if brandTaglineText %}
            <div class="brand-tagline">{{ brandTaglineText }}</div>
            {% endif %}
          </a>
          {% if activeBrand and activeBrand.crossLink %}
          <a
            class="brand-cross-link"
            href="{{ activeBrand.crossLink.href | url }}"
            aria-label="{{ activeBrand.crossLink.label }}로 이동"
          >{{ activeBrand.crossLink.label }}</a>
          {% endif %}
        </div>

        {% if activeBrand %}
        <nav class="nav">
          {% for item in activeBrand.nav %}
          <a
            href="{{ item.href | url }}"
            {% if page.url == item.href or (item.matchPrefix and page.url.startsWith(item.matchPrefix)) %}class="active"{% endif %}
          >{{ item.label }}</a>
          {% endfor %}
        </nav>

        <button class="menu-btn" id="menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="sidebar-drawer">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
        {% else %}
        <nav class="nav hub-nav">
          <a href="{{ '/devbyhwang/' | url }}">DevByHwang</a>
          <a href="{{ '/dodoes/' | url }}">Underground Novel</a>
        </nav>
        {% endif %}
      </div>
    </header>

    <div class="site-wrap">
      <main class="site-main">{{ content | safe }}</main>

      <footer class="footer footer-minimal">
        {% set footerLabel = activeBrand.displayName if activeBrand else site.author %}
        {% set footerYearSource = brandNewest or overallNewest %}
        {% if footerYearSource %}
          {% set footerYear = footerYearSource.date | readableDate('yyyy') %}
        {% else %}
          {% set footerYear = '' %}
        {% endif %}
        <div class="footer-meta">
          <span>© {{ footerLabel }}{% if footerYear %} {{ footerYear }}{% endif %}</span>
          <span>Licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/">CC BY-NC-SA 4.0</a></span>
        </div>
      </footer>
    </div>

    {% if activeBrand and activeBrand.features.visitorCounter and env.isProd %}
      {% if site.visitorCounter and site.visitorCounter.enable %}
        <div
          data-visitor-counter
          data-namespace="{{ site.visitorCounter.namespace }}"
          data-total-key="{{ site.visitorCounter.totalKey }}"
          data-daily-prefix="{{ site.visitorCounter.dailyPrefix }}"
          data-timezone="{{ site.visitorCounter.timeZone }}"
          data-today-id="visitor-today"
          data-total-id="visitor-total"
          hidden
        ></div>
        <script src="{{ '/assets/visitor-counter.js' | url }}" defer></script>
      {% endif %}
    {% endif %}
    {% if activeBrand and env.isProd and site.postViews and site.postViews.enable %}
      <div
        data-post-views-config
        data-namespace="{{ site.postViews.namespace }}"
        data-counter-prefix="{{ site.postViews.counterPrefix }}"
        data-timezone="{{ site.postViews.timeZone }}"
        data-path-prefix="{{ env.pathPrefix }}"
        hidden
      ></div>
      <script src="{{ '/assets/post-views.js' | url }}" defer></script>
    {% endif %}
    {% if activeBrand and activeBrand.features.ads and site.googleAds.enable and site.googleAds.client and env.isProd %}
      <script src="{{ '/assets/ads-init.js' | url }}" defer></script>
    {% endif %}
    <script src="{{ '/assets/base-ui.js' | url }}" defer></script>
  </body>
</html>
