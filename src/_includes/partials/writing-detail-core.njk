{% set detailBrand = brands[brandKey] %}
{% set detailDefaultCategory = defaultCategory or 'notes' %}
{% set detailRelated = relatedCollection or [] %}
{% set detailRailMode = postRailMode or 'both' %}
{% set detailShowExcerpt = showDetailExcerpt === true %}
{% set detailContentWithHeadings = content | addHeadingIds %}
{% set detailTocItems = detailContentWithHeadings | extractHeadings %}
{% set detailHasShell = showRails or showPostToc %}
{% if renderInlineAds %}
  {% set detailContent = detailContentWithHeadings | injectInlineAds(site, env) %}
{% else %}
  {% set detailContent = detailContentWithHeadings %}
{% endif %}

{% if detailHasShell %}
<div class="post-detail-rails{% if detailRailMode == 'left-only' %} post-detail-rails-left-only{% endif %}{% if showPostToc and not showRails %} post-detail-toc-only{% endif %}">
  {% if showRails %}
  <aside class="post-rail post-rail-left" aria-label="왼쪽 광고 영역">
    <div class="post-rail-sticky">
      {% set adDisplaySlot = site.googleAds.railDisplaySlot or site.googleAds.defaultSlot %}
      {% set adDisplayFormat = adRailDisplayFormat or "vertical" %}
      {% set adDisplayKind = "rail-display" %}
      {% set adDisplayClass = "ad-shell-rail" %}
      {% set adDisplayPlaceholder = true %}
      {% include "ads/display.njk" %}
    </div>
  </aside>
  {% endif %}

  <div class="post-detail-main">
{% endif %}

  <article class="writing-note">
    <header class="writing-header">
      {% if showKicker !== false %}
      <div class="writing-kicker">{{ category or detailDefaultCategory }}</div>
      {% endif %}
      <h1 class="writing-title">{{ title }}</h1>
      {% if detailShowExcerpt and excerpt %}
      <p class="writing-description">{{ excerpt }}</p>
      {% endif %}
      <div class="writing-meta">
        {% if writingDateFormat %}
        <span class="writing-date">{{ date | readableDate(writingDateFormat) }}</span>
        {% else %}
        <span class="writing-date">{{ date | readableDate }}</span>
        {% endif %}
        <span class="writing-author">{% if showAuthorByPrefix !== false %}by {% endif %}{{ detailAuthorLabel or detailBrand.displayName }}</span>
      </div>
    </header>

    <div class="writing-content prose">
      {{ detailContent | safe }}
    </div>

  </article>

  {% set relatedPosts = detailRelated | hybridRelatedPosts(page.url, 4) %}
  <section class="related-posts writing-related-posts">
    <div class="section-header">
      <h2>이 글 다음으로 읽기</h2>
    </div>
    {% if relatedPosts.length > 0 %}
    <ol class="writing-related-list">
      {% for item in relatedPosts %}
        <li>
          <a class="writing-related-link" href="{{ item.post.url | url }}">
            <span class="writing-related-body">
              <span class="writing-related-title">{{ item.post.data.title }}</span>
              <span class="writing-related-meta">{{ item.post.data.category | default(detailDefaultCategory) }} · {{ item.post.date | readableDate }}</span>
            </span>
          </a>
        </li>
      {% endfor %}
    </ol>
    {% else %}
    <p class="muted">아직 추천할 글이 없습니다.</p>
    {% endif %}
  </section>

  {% if showMultiplexAd %}
    {% include "ads/multiplex.njk" %}
  {% endif %}

{% if detailHasShell %}
  </div>

  {% if showPostToc and detailTocItems.length > 0 %}
  <aside class="post-toc" aria-label="글 목차">
    <nav class="post-toc-inner">
      <div class="post-toc-rail" aria-hidden="true">
        {% for heading in detailTocItems %}
        <span class="post-toc-rail-marker post-toc-rail-level-{{ heading.level }}" data-toc-target="{{ heading.id }}"></span>
        {% endfor %}
      </div>
      <div class="post-toc-flyout">
        {% for heading in detailTocItems %}
        <div class="post-toc-item post-toc-level-{{ heading.level }}">
          <a class="post-toc-link" href="#{{ heading.id }}">{{ heading.text }}</a>
        </div>
        {% endfor %}
      </div>
    </nav>
  </aside>
  {% endif %}

  {% if showRails and detailRailMode != 'left-only' %}
  <aside class="post-rail post-rail-right" aria-label="오른쪽 광고 영역">
    <div class="post-rail-sticky">
      {% set adDisplaySlot = site.googleAds.railDisplaySlot or site.googleAds.defaultSlot %}
      {% set adDisplayFormat = adRailDisplayFormat or "vertical" %}
      {% set adDisplayKind = "rail-display" %}
      {% set adDisplayClass = "ad-shell-rail" %}
      {% set adDisplayPlaceholder = true %}
      {% include "ads/display.njk" %}
    </div>
  </aside>
  {% endif %}
</div>
{% endif %}
