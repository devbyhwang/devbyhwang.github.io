---
layout: layouts/base.njk
brand: dodoes
title: 홈
description: "Underground Novel 최신 글"
---
{% set homePostLimit = 6 %}
{% set dodoesPosts = collections.dodoesWriting %}
<section class="page-hero">
  <h1>최신 글</h1>
</section>

<section class="layout-two">
  <div class="feed">
    {% set posts = dodoesPosts %}
    {% set defaultCategory = "notes" %}
    {% set limit = homePostLimit %}
    {% set emptyMessage = "아직 글이 없습니다." %}
    {% set listClass = "post-list archive-list writing-feed-list" %}
    {% set itemClass = "writing-feed-item" %}
    {% set showExcerpt = true %}
    {% include "partials/writing-feed-cards.njk" %}
    {% if dodoesPosts.length > homePostLimit %}
    <div class="section-more-row">
      <a class="section-more-link" href="{{ '/dodoes/posts/' | url }}" aria-label="글 더보기">더보기</a>
    </div>
    {% endif %}
  </div>

  <aside class="sidebar">
    <div class="sidebar-categories">
      <div class="sidebar-title">카테고리</div>
      <ul class="category-tree">
        <li>
          <a href="{{ '/dodoes/posts/' | url }}">전체 글</a>
          <span class="count">({{ dodoesPosts | length }})</span>
        </li>
        {% for cat in collections.dodoesCategoryList %}
          <li class="sub">
            <a href="{{ ('/dodoes/categories/' + cat.key + '/') | url }}">{{ cat.name }}</a>
            <span class="count">({{ cat.count }})</span>
          </li>
        {% endfor %}
      </ul>
    </div>

  </aside>
</section>
