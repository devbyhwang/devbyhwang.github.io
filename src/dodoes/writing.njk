---
layout: layouts/base.njk
brand: dodoes
title: 글
description: "Underground Novel 글 아카이브"
permalink: /dodoes/writing/
---
{% set dodoesPosts = collections.dodoesWriting %}
{% set dodoesPopularPosts = collections.dodoesPopularPosts %}
{% set dodoesPopularCandidates = dodoesPosts | postViewCandidates %}
<section class="page-hero">
  <h1>글</h1>
</section>

<section class="layout-two archive">
  <div class="feed">
    {% set posts = dodoesPosts %}
    {% set defaultCategory = "notes" %}
    {% set emptyMessage = "아직 글이 없습니다." %}
    {% set listClass = "post-list archive-list writing-feed-list" %}
    {% set itemClass = "writing-feed-item" %}
    {% set showExcerpt = true %}
    {% include "partials/writing-feed-cards.njk" %}
  </div>

  <aside class="sidebar">
    <div class="sidebar-categories">
      <div class="sidebar-title">카테고리</div>
      <ul class="category-tree">
        {% for cat in collections.dodoesCategoryList %}
          <li>
            <a href="{{ ('/dodoes/categories/' + cat.key + '/') | url }}">{{ cat.name }}</a>
            <span class="count">({{ cat.count }})</span>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div class="sidebar-posts">
      <div class="tab-buttons">
        <button class="tab-btn" data-tab="recent">최근글</button>
        <button class="tab-btn active" data-tab="popular">인기글</button>
      </div>
      <ul class="post-list-tab" data-content="recent">
        {% if dodoesPosts.length > 0 %}
        {% for post in dodoesPosts | head(5) %}
          <li><a href="{{ post.url | url }}">{{ post.data.title }}</a></li>
        {% endfor %}
        {% else %}
          <li class="muted">아직 글이 없습니다.</li>
        {% endif %}
      </ul>
      <ul class="post-list-tab active" data-content="popular" data-popular-list data-popular-brand="dodoes">
        {% if dodoesPopularPosts.length > 0 %}
        {% for post in dodoesPopularPosts | head(5) %}
          <li><a href="{{ post.url | url }}">{{ post.data.title }}</a></li>
        {% endfor %}
        {% else %}
          <li class="muted">아직 글이 없습니다.</li>
        {% endif %}
      </ul>
    </div>
  </aside>
</section>
<script type="application/json" data-popular-candidates="dodoes">{{ dodoesPopularCandidates | jsonScript | safe }}</script>
