---
layout: layouts/base.njk
brand: dodoes
title: 글
description: "Underground Novel 글 아카이브"
permalink: /dodoes/writing/
---
<section class="page-hero">
  <h1>글</h1>
</section>

<section class="layout-two archive">
  <div class="feed">
    <div class="post-list archive-list dodoes-feed-list">
      {% for post in collections.dodoesWriting %}
      <a class="post-item compact dodoes-feed-item" href="{{ post.url | url }}">
        <div class="post-item-top">
          <span class="badge">{{ post.data.category | default('notes') }}</span>
          <span class="post-meta">{{ post.date | readableDate }}</span>
        </div>
        <div class="post-item-title">{{ post.data.title }}</div>
        {% if post.data.description or post.data.excerpt %}
        <div class="post-item-excerpt muted">{{ post.data.excerpt or post.data.description }}</div>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </div>

  <aside class="sidebar">
    <div class="sidebar-categories">
      <div class="sidebar-title">카테고리</div>
      <ul class="category-tree">
        {% for cat in collections.dodoesCategoryList %}
          <li>
            <a href="{{ ('/dodoes/categories/' + cat.key + '/') | url }}">{{ cat.name }}</a>
            <span class="count">({{ cat.count }})</span>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div class="sidebar-posts">
      <div class="tab-buttons">
        <button class="tab-btn active" data-tab="recent">최근글</button>
        <button class="tab-btn" data-tab="popular">인기글</button>
      </div>
      <ul class="post-list-tab active" data-content="recent">
        {% for post in collections.dodoesWriting | head(5) %}
          <li><a href="{{ post.url | url }}">{{ post.data.title }}</a></li>
        {% endfor %}
      </ul>
      <ul class="post-list-tab" data-content="popular">
        {% for post in collections.dodoesPopularPosts | head(5) %}
          <li><a href="{{ post.url | url }}">{{ post.data.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </aside>
</section>
