# Site
SITE_URL=https://your-domain.com

# Google Ads
GOOGLE_ADS_CLIENT=
GOOGLE_ADS_ENABLE=false
# Common/inline ads slot (empty or 0000000000 = disabled)
GOOGLE_ADS_SLOT_DEFAULT=
# Playground bottom ads slot (empty or 0000000000 = disabled)
GOOGLE_ADS_PLAYGROUND_BOTTOM_SLOT=

# Visitor Counter
VISITOR_COUNTER_ENABLE=false
VISITOR_COUNTER_NAMESPACE=
VISITOR_COUNTER_TOTAL_KEY=total
VISITOR_COUNTER_DAILY_PREFIX=daily
VISITOR_COUNTER_TIMEZONE=Asia/Seoul

# Giscus (GitHub Discussions)
GISCUS_ENABLE=true
GISCUS_REPO=devbyhwang/devbyhwang.github.io
GISCUS_REPO_ID=
GISCUS_CATEGORY=Announcements
GISCUS_CATEGORY_ID=
